    {
      "id": "version-gap",
      "finding": "Spec info.version is 2.1.0 while current release checked is v2.9.1.",
      "recommendation": "Derive or explain the API schema version."
    },
    {
      "id": "host-gap",
      "finding": "Spec host localhost appears 289 times in generated API HTML.",
      "recommendation": "Document deployment base URL substitution."
    },
    {
      "id": "description-gap",
      "finding": "24 of 41 operations lack description.",
      "recommendation": "Add behavioral prose for mutations, tokens, pagination, uploads and streaming."
    },
    {
      "id": "security-gap",
      "finding": "No global security and 8 operations omit operation-level security.",
      "recommendation": "Mark public and protected operations explicitly."
    },
    {
      "id": "guide-gap",
      "finding": "Quick mode yields reference but no workflow guides.",
      "recommendation": "Add auth, first-message, streaming, pagination and elevation guides."
    }
